PORT=5000
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
SCRAPE_KEY=replace-with-a-secret-key
GROQ_API_KEY=gsk_your-groq-key
HF_API_KEY=hf_your-huggingface-token
# Set to true on Railway so the hourly scrape+analyze cron runs 24/7
ENABLE_CRON=true
